# Database Configuration
# SQLite database file path - will be created automatically
DATABASE_URL=sqlite:///./data/distroviz.db

# Backend Service Configuration
# Port for FastAPI backend service
BACKEND_PORT=8000

# Frontend Service Configuration
# Port for React frontend application
FRONTEND_PORT=3000

# CORS Configuration
# Allowed origins for cross-origin requests (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Development Settings
# Set to 'development' for debug mode, 'production' for optimized builds
NODE_ENV=production

# API Configuration
# Base URL for API requests from frontend
VITE_API_URL=http://localhost:8000

# Docker Configuration
# Compose project name to avoid conflicts
COMPOSE_PROJECT_NAME=distroviz-v3